<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>Blogpage</title>
        <link rel="stylesheet" href="/styles/blog.css">

</head>

<body>
    <%- include('./partials/nav') %>
        <div class="container mt-3">
            <h1>
                <%= blog.title %>
            </h1>
            <% if (blog.coverImageURL) { %>
                <img src="<%= blog.coverImageURL %>" alt="Cover Image" class="img-fluid mb-3" width="700px">
                <% } %>
                    <p>
                        <%= blog.body %>
                    </p>
                    <span style="height: 4vh;">
                        <div class="creted">
                            <small class="text-muted">
                                <% if (blog.coverImageURL) { %>
                                    <img src="<%= blog.createdBy.profileImageUrl %>" alt="Cover Image">
                                    <% } %>
                                        Written by <%= blog.createdBy.fullName || 'Unknown' %><br>
                        </div>
                        Posted on <%= new Date(blog.createdAt).toLocaleDateString() %>

                            </small>
                    </span>

                    <div class="comment-section">
                        <h3>Leave a Comment (<%= comments.length %>)</h3>
                        <% if (locals.user) { %>
                            <form action="/blog/comment/<%= blog._id %>" method="POST">
                                <input type="hidden" name="blogId" value="<%= blog._id %>">
                                <textarea name="comment" rows="1" placeholder="Write your comment here..."
                                    required></textarea>
                                <button type="submit">Post Comment</button>
                            </form>
                            <% } %>
                    </div>
                    <h3 class="mt-4 mb-3">Comments</h3>
                    <div class="comment-box">
                        <% comments.forEach(comment => { %>
                            <div class="single-comment">
                                <div class="comment-header">
                                    <img src="<%= comment.createdBy?.profileImageUrl || '/default-user.png' %>" alt="User" class="comment-user-img">
                                    <strong><%= comment.createdBy?.fullName || 'Anonymous' %></strong>
                                    <span class="comment-date"><%= new Date(comment.createdAt).toLocaleDateString() %></span>
                                </div>
                                <p class="comment-content"><%= comment.content %></p>
                            </div>
                        <% }) %>
                    </div>
                    
        </div>


        <%- include('./partials/scripts') %>
</body>

</html>